---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';
import sectors from '../data/sectors.json';

const base = import.meta.env.BASE_URL;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Sermont Maquinaria",
  "url": "https://www.sermont.es",
  "logo": "https://www.sermont.es/logo.png",
  "description": "Sermont, S.A.  distribuye en España, las mejores marcas internacionales de sistemas de lavado industrial. Representantes de NERKON y JEROS en España y Portugal.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Barcelona",
    "addressCountry": "ES"
  },
  "telephone": "+34934231510",
  "email": "info@sermont.es",
  "sameAs": []
};
---

<BaseLayout 
  title="Sermont | Soluciones de Lavado Industrial - Nerkon & Jeros"
  description="Sermont, S.A.  distribuye en España, las mejores marcas internacionales de sistemas de lavado industrial. Representantes de NERKON y JEROS en España y Portugal."
  activePage="home"
  jsonLd={jsonLd}
>

    <!-- HERO SECTION -->
    <section id="hero-section" class="min-h-[85vh] flex flex-col justify-center items-center text-center text-white px-4 pt-24 pb-16 bg-cover bg-center relative overflow-hidden">
        <!-- Carrusel de fondos -->
        <div class="absolute inset-0 z-0">
            {sectors.map((sector, index) => (
                <div 
                    class={`hero-bg absolute inset-0 bg-cover bg-center transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                    data-index={index}
                    style={`background: linear-gradient(rgba(10, 25, 47, 0.70), rgba(10, 25, 47, 0.70)), url('${sector.hero.bgImage}'); background-size: cover; background-position: center;`}
                ></div>
            ))}
        </div>

        <!-- Contenido sobre el fondo -->
        <h1 class="relative z-10 text-5xl md:text-7xl font-bold max-w-5xl mb-8 leading-tight mx-auto">Soluciones de Lavado Industrial</h1>
        <p class="relative z-10 text-xl text-gray-300 max-w-2xl mb-12 font-light mx-auto">Sermont, S.A.  distribuye en España, las mejores marcas internacionales de sistemas de lavado industrial para los siguientes sectores:</p>
        
        <!-- SECTOR GRID -->
        <div id="industrias" class="relative z-10 flex flex-wrap justify-center w-full max-w-7xl mb-10 overflow-visible mx-auto">
            
            <!-- FILA 1 (5 ELEMENTOS) -->
            <div class="flex w-full justify-center">
                {sectors.slice(0, 5).map((sector, i) => {
                    const roundedClass = i === 0 ? 'rounded-tl-3xl' : i === 4 ? 'rounded-tr-3xl' : '';
                    const borderClass = i < 4 ? 'border-r' : '';
                    return (
                        <a href={`${base}sector/${sector.slug}`} class={`sector-card w-1/5 p-10 flex flex-col items-center border-b border-white/10 ${borderClass} border-white/10 ${roundedClass} bg-white/5 backdrop-blur-sm border border-white/10 transition-all duration-300 hover:bg-[#a6192e] hover:-translate-y-1 hover:rounded-xl hover:z-10`}>
                            <svg class="w-14 h-14 mb-4 text-blue-400 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <Fragment set:html={sector.icon} />
                            </svg>
                            <span class="text-[10px] font-bold uppercase tracking-widest text-center leading-tight">{sector.name}</span>
                        </a>
                    );
                })}
            </div>

            <!-- FILA 2 (5 ELEMENTOS) -->
            <div class="flex w-full justify-center">
                {sectors.slice(5, 10).map((sector, i) => {
                    const roundedClass = i === 0 ? 'rounded-bl-3xl' : i === 4 ? 'rounded-br-3xl' : '';
                    const borderClass = i < 4 ? 'border-r' : '';
                    return (
                        <a href={`${base}sector/${sector.slug}`} class={`sector-card w-1/5 p-10 flex flex-col items-center ${borderClass} border-white/10 ${roundedClass} bg-white/5 backdrop-blur-sm border border-white/10 transition-all duration-300 hover:bg-[#a6192e] hover:-translate-y-1 hover:rounded-xl hover:z-10`}>
                            <svg class="w-14 h-14 mb-4 text-blue-400 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <Fragment set:html={sector.icon} />
                            </svg>
                            <span class="text-[10px] font-bold uppercase tracking-widest text-center leading-tight">{sector.name}</span>
                        </a>
                    );
                })}
            </div>
        </div>

        <a href={`${base}maquinaria`} class="relative z-10 bg-white text-[#0a192f] hover:bg-[#a6192e] hover:text-white px-8 py-4 rounded-full font-bold transition shadow-xl uppercase text-sm tracking-wider">
            Ver todas las máquinas
        </a>
    </section>

    <script>
        // Carrusel automático de fondos
        let currentBgIndex = 0;
        const backgrounds = document.querySelectorAll('.hero-bg');
        const totalBackgrounds = backgrounds.length;

        function rotateBackground() {
            // Ocultar el fondo actual
            backgrounds[currentBgIndex].style.opacity = '0';
            
            // Calcular el siguiente índice
            currentBgIndex = (currentBgIndex + 1) % totalBackgrounds;
            
            // Mostrar el siguiente fondo
            backgrounds[currentBgIndex].style.opacity = '1';
        }

        // Rotar cada 5 segundos
        setInterval(rotateBackground, 5000);
    </script>

    <!-- SOBRE SERMONT -->
    <section id="nosotros" class="py-24 px-6 bg-white">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-20 items-center">
            <div class="relative flex items-center justify-center group">
                <!-- Círculos decorativos de fondo -->
                <div class="absolute -top-8 -left-8 w-32 h-32 bg-gradient-to-br from-[#a6192e]/10 to-[#0033A0]/10 rounded-full blur-2xl group-hover:scale-110 transition-transform duration-700"></div>
                <div class="absolute -bottom-8 -right-8 w-40 h-40 bg-gradient-to-tr from-[#0033A0]/10 to-[#a6192e]/10 rounded-full blur-2xl group-hover:scale-110 transition-transform duration-700"></div>
                
                <!-- Contenedor del logo con efectos -->
                <div class="relative bg-gradient-to-br from-gray-50 to-white p-12 rounded-2xl shadow-xl border border-gray-100 group-hover:shadow-2xl group-hover:border-[#a6192e]/20 transition-all duration-500">
                    <!-- Borde decorativo animado -->
                    <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-[#a6192e]/0 via-[#a6192e]/5 to-[#0033A0]/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    
                    <!-- Logo -->
                    <img src="/sermont-web/images/logos/logotipo-sermont.jpg" alt="Sermont Logo" class="relative w-full max-w-sm object-contain group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async">
                    
                    <!-- Badge decorativo -->
                    <div class="absolute -top-4 -right-4 bg-[#a6192e] text-white px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider shadow-lg group-hover:scale-110 transition-transform duration-300">
                        Desde 1963
                    </div>
                </div>
            </div>
            <div>
                <h3 class="text-[#a6192e] font-bold uppercase tracking-[0.3em] text-xs mb-4">Sobre Nosotros</h3>
                <h2 class="text-4xl font-bold text-[#0a192f] mb-8 leading-tight">60 años de experiencia en el sector de la higiene industrial.</h2>
                <p class="text-gray-600 mb-8 leading-relaxed text-lg">
                    En <strong>Sermont</strong>, nos especializamos en la integración de líneas completas de lavado. No solo suministramos equipos, diseñamos procesos eficientes que ahorran agua, energía y tiempo, garantizando la máxima higiene en sectores críticos.
                </p>
                <p class="text-gray-600 mb-8 leading-relaxed text-lg">
                Sermont S.A. distribuye los mejores sistemas de higiene que hay en el mercado internacional tanto dentro como fuera del sector alimentario. Desde 1963 sermont distribuye en España marcas líderes en diferentes ámbitos, en lo que se refiere a los sistemas de higiene, tiene la distribución en exclusiva de la marca danesa JEROS.  
                </p>
                <div class="flex flex-wrap gap-4 mt-10">
                    <span class="px-6 py-3 border border-gray-300 rounded text-xs font-bold text-[#0a192f] hover:bg-gray-50 transition uppercase tracking-widest cursor-pointer">Ver NERKON</span>
                    <a href={`${base}jeros`} class="px-6 py-3 border border-gray-300 rounded text-xs font-bold text-[#0a192f] hover:bg-gray-50 transition uppercase tracking-widest">Ver JEROS</a>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN VALORES -->
    <section class="py-24 bg-slate-100">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid md:grid-cols-3 gap-10">
                <div class="bg-white p-10 rounded-xl shadow-sm hover:shadow-xl transition-all border-b-4 border-transparent hover:border-[#a6192e]">
                    <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mb-6 mx-auto text-[#0a192f]">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-4 text-[#0a192f] text-center">Servicio técnico y
comercial al cliente
</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-6 text-center">Servicio técnico oficial y asesoramiento comercial aplicando todos los procesos y estándares de calidad de nuestras marcas representadas.</p>
                    <div class="text-center pt-4 border-t border-slate-100">
                        <span class="text-sm font-bold text-slate-400 block mb-1 uppercase tracking-widest">Contacto SAT</span>
                        <p class="text-lg font-bold text-[#a6192e]">93 423 15 10</p>
                    </div>
                </div>
                <div class="bg-white p-10 rounded-xl shadow-sm hover:shadow-xl transition-all border-b-4 border-transparent hover:border-[#a6192e]">
                    <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mb-6 mx-auto text-[#0a192f]">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-4 text-[#0a192f] text-center">Calidad</h3>
                    <p class="text-gray-500 text-sm leading-relaxed text-center">Garantizamos la máxima fiabilidad y funcionamiento en todas las máquinas.</p>
                </div>
                <div class="bg-white p-10 rounded-xl shadow-sm hover:shadow-xl transition-all border-b-4 border-transparent hover:border-[#a6192e]">
                    <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mb-6 mx-auto text-[#0a192f]">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-4 text-[#0a192f] text-center">Precio</h3>
                    <p class="text-gray-500 text-sm leading-relaxed text-center">Garantizamos la mejor relación precio y longevidad en todas las operaciones de venta.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN CLIENTES -->
    <section class="py-24 bg-white border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-16 italic">Empresas que confían en nuestra tecnología</h3>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-12 items-center">
                <img src="https://upload.wikimedia.org/wikipedia/commons/c/ce/Coca-Cola_logo.svg" alt="Coca Cola" class="h-6 mx-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all" loading="lazy">
                <img src="https://upload.wikimedia.org/wikipedia/commons/a/a6/Logo_NIKE.svg" alt="Nike" class="h-8 mx-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all" loading="lazy">
                <img src="https://upload.wikimedia.org/wikipedia/commons/c/ce/Coca-Cola_logo.svg" alt="Coca Cola" class="h-6 mx-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all" loading="lazy">
                <img src="https://upload.wikimedia.org/wikipedia/commons/a/a6/Logo_NIKE.svg" alt="Nike" class="h-8 mx-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all" loading="lazy">
                <img src="https://upload.wikimedia.org/wikipedia/commons/c/ce/Coca-Cola_logo.svg" alt="Coca Cola" class="h-6 mx-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all" loading="lazy">
                <img src="https://upload.wikimedia.org/wikipedia/commons/a/a6/Logo_NIKE.svg" alt="Nike" class="h-8 mx-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all" loading="lazy">
            </div>
        </div>
    </section>

    <!-- FORMULARIO DE CONTACTO -->
    <ContactSection />

</BaseLayout>

<style>
    .sector-card:hover svg {
        color: #ffffff;
    }
</style>
